# SSHD Log Security Analysis
# Detects common attack patterns and suspicious activities

note: Checking for suspicious SSH activities

# 1. Failed login attempts (brute force indicators)
note: Detecting failed login attempts
regexp: Failed \s+ password
generator: <<CODE
!powershell

$matched_list = matched

if ($matched_list.Count -gt 0) {
  Write-Host "assert: 1 failed password attempt detected"
  Write-Host "note: Total failed attempts: $($matched_list.Count)"
  Write-Host "note: Last 10 failed login attempts:"
  $last_ten = $matched_list[-10..-1]
  foreach ($entry in $last_ten) {
    Write-Host "note:   $entry"
  }
} else {
  Write-Host "assert: 1 no failed attempts found"
}

CODE

# 2. Invalid user attempts
note: Detecting invalid user login attempts
regexp: Invalid \s+ user
generator: <<CODE
!powershell

$matched_list = matched

if ($matched_list.Count -gt 0) {
  Write-Host "assert: 1 invalid user attempts detected: $($matched_list.Count) attempts"
  Write-Host "note: Last 10 invalid user attempts:"
