# SSHD Log Security Analysis
# Detects common attack patterns and suspicious activities

note: Checking for suspicious SSH activities

# 1. Failed login attempts (brute force indicators)
note: Detecting failed login attempts
regexp: Failed \s+ password
generator: <<CODE
!raku
if matched().elems > 0 {
  say "assert: 1 failed password attempt detected";
  say "note: Total failed attempts: {matched().elems}";
  say "note: Last 10 failed login attempts:";
  my @last_ten = matched()[*-10..*];
  for @last_ten -> $entry {
    say "note:   {$entry}";
  }
} else {
  say "assert: 1 no failed attempts found";
}
CODE

# 2. Invalid user attempts
note: Detecting invalid user login attempts
regexp: Invalid \s+ user
generator: <<CODE
!raku
if matched().elems > 0 {
  say "assert: 1 invalid user attempts detected: {matched().elems} attempts";
