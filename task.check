# 10. IP-based attack patterns (capture and analyze)
note: Analyzing IP patterns for brute force
regexp: (\d+\.\d+\.\d+\.\d+)
generator: <<CODE
!python
from sparrow6lib import *

if len(captures()) > 0:
  ip_count = {}
  for cap in captures():
    ip = cap[0]
    ip_count[ip] = ip_count.get(ip, 0) + 1
  
  print("assert: 1 IP analysis complete: {} unique IPs".format(len(ip_count)))
  print("note: Last 10 IP entries:")
  last_ten = matched()[-10:]
  for entry in last_ten:
    print("note:   {}".format(entry))
  
  sorted_ips = sorted(ip_count.items(), key=lambda x: x[1], reverse=True)[:10]
  print("note: Top IPs by event frequency:")
  for ip, count in sorted_ips:
    if count > 5:
      print("assert: 0 suspicious IP {}: {} events (possible brute force)".format(ip, count))
    else:
      print("note:   IP {}: {} events".format(ip, count))
else:
  print("assert: 1 no IP addresses found")
CODE

