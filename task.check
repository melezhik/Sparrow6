else
  puts "assert: 1 no invalid user attempts"
end

CODE

# 3. Root login attempts (potential security concern)
note: Detecting root login attempts
regexp: [ root || ROOT ]
generator: <<CODE
!ruby

matched_list = matched()

if matched_list.length > 0
  puts "assert: 1 root login attempts detected"
  puts "note: Total root-related events: #{matched_list.length}"
