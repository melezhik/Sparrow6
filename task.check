# SSHD Log Security Analysis
# Detects common attack patterns and suspicious activities

note: Checking for suspicious SSH activities

# 1. Failed login attempts (brute force indicators)
note: Detecting failed login attempts
regexp: Failed \s+ password
generator: <<CODE
!php
<?php

$matched_list = matched();

if (count($matched_list) > 0) {
  echo "assert: 1 failed password attempt detected\n";
  echo "note: Total failed attempts: " . count($matched_list) . "\n";
  echo "note: Last 10 failed login attempts:\n";
  $last_ten = array_slice($matched_list, -10);
  foreach ($last_ten as $entry) {
    echo "note:   " . $entry . "\n";
  }
} else {
  echo "assert: 1 no failed attempts found\n";
}

?>
CODE

