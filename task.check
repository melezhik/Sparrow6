# 10. IP-based attack patterns (capture and analyze)
note: Analyzing IP patterns for brute force
regexp: (\d+\.\d+\.\d+\.\d+)
generator: <<CODE
!raku
if captures().elems > 0 {
  my %ip_count;
  for captures() -> $cap {
    my $ip = $cap[0];
    %ip_count{$ip}++;
  }
  
  say "assert: 1 IP analysis complete: {%ip_count.elems} unique IPs";
  say "note: Last 10 IP entries:";
  my @last_ten = matched()[*-10..*];
  for @last_ten -> $entry {
    say "note:   {$entry}";
  }
  
  my @high_freq = %ip_count.sort(*.value).reverse[0..9];
  say "note: Top IPs by event frequency:";
  for @high_freq -> $pair {
    if $pair.value > 5 {
      say "assert: 0 suspicious IP {$pair.key}: {$pair.value} events (possible brute force)";
    } else {
      say "note:   IP {$pair.key}: {$pair.value} events";
    }
  }
} else {
  say "assert: 1 no IP addresses found";
}
CODE

# 11. Brute force detection summary
note: Brute force pattern analysis
generator: <<CODE
!raku
say "assert: 1 SSHD log analysis complete";
say "note: Summary: Review events above for security threats";
say "note: Suspicious patterns indicated by 'assert: 0' lines";
CODE

