CODE

# 10. IP-based attack patterns (capture and analyze)
note: Analyzing IP patterns for brute force
regexp: (\d+\.\d+\.\d+\.\d+)
generator: <<CODE
!ruby

captures_list = captures()

if captures_list.length > 0
  ip_count = Hash.new(0)
  captures_list.each do |cap|
    ip = cap[0]
    ip_count[ip] += 1
  end
  
  puts "assert: 1 IP analysis complete: #{ip_count.length} unique IPs"
  puts "note: Last 10 IP entries:"
  matched_list = matched()
  last_ten = matched_list.last(10)
  last_ten.each do |entry|
    puts "note:   #{entry}"
  end
  
  sorted_ips = ip_count.sort_by { |ip, count| -count }.first(10)
  puts "note: Top IPs by event frequency:"
  sorted_ips.each do |ip, count|
    if count > 5
      puts "assert: 0 suspicious IP #{ip}: #{count} events (possible brute force)"
    else
      puts "note:   IP #{ip}: #{count} events"
    end
  end
else
  puts "assert: 1 no IP addresses found"
end

CODE

# 11. Brute force detection summary
note: Brute force pattern analysis
generator: <<CODE
!ruby

puts "assert: 1 SSHD log analysis complete"
puts "note: Summary: Review events above for security threats"
puts "note: Suspicious patterns indicated by 'assert: 0' lines"

