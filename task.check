# 10. IP-based attack patterns (capture and analyze)
note: Analyzing IP patterns for brute force
regexp: (\d+\.\d+\.\d+\.\d+)
generator: <<CODE
!php
<?php

$captures_list = captures();

if (count($captures_list) > 0) {
  $ip_count = array();
  foreach ($captures_list as $cap) {
    $ip = $cap[0];
    if (isset($ip_count[$ip])) {
      $ip_count[$ip]++;
    } else {
      $ip_count[$ip] = 1;
    }
  }
  
  echo "assert: 1 IP analysis complete: " . count($ip_count) . " unique IPs\n";
  echo "note: Last 10 IP entries:\n";
  $matched_list = matched();
  $last_ten = array_slice($matched_list, -10);
  foreach ($last_ten as $entry) {
    echo "note:   " . $entry . "\n";
  }
  
  arsort($ip_count);
  $top_ips = array_slice($ip_count, 0, 10, true);
  echo "note: Top IPs by event frequency:\n";
  foreach ($top_ips as $ip => $count) {
    if ($count > 5) {
      echo "assert: 0 suspicious IP " . $ip . ": " . $count . " events (possible brute force)\n";
    } else {
      echo "note:   IP " . $ip . ": " . $count . " events\n";
    }
  }
} else {
  echo "assert: 1 no IP addresses found\n";
}

?>
CODE

