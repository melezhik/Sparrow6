# 10. IP-based attack patterns (capture and analyze)
note: Analyzing IP patterns for brute force
regexp: (\d+\.\d+\.\d+\.\d+)
generator: <<CODE
!powershell

$captures_list = captures

if ($captures_list.Count -gt 0) {
  $ip_count = @{}
  foreach ($cap in $captures_list) {
    $ip = $cap[0]
    if ($ip_count.ContainsKey($ip)) {
      $ip_count[$ip]++
    } else {
      $ip_count[$ip] = 1
    }
  }
  
  Write-Host "assert: 1 IP analysis complete: $($ip_count.Count) unique IPs"
  Write-Host "note: Last 10 IP entries:"
  $matched_list = matched
  $last_ten = $matched_list[-10..-1]
  foreach ($entry in $last_ten) {
    Write-Host "note:   $entry"
  }
  
  $sorted_ips = $ip_count.GetEnumerator() | Sort-Object -Property Value -Descending | Select-Object -First 10
  Write-Host "note: Top IPs by event frequency:"
  foreach ($pair in $sorted_ips) {
    if ($pair.Value -gt 5) {
      Write-Host "assert: 0 suspicious IP $($pair.Key): $($pair.Value) events (possible brute force)"
    } else {
      Write-Host "note:   IP $($pair.Key): $($pair.Value) events"
    }
  }
} else {
  Write-Host "assert: 1 no IP addresses found"
}

CODE

# 11. Brute force detection summary
note: Brute force pattern analysis
generator: <<CODE
!powershell

Write-Host "assert: 1 SSHD log analysis complete"
Write-Host "note: Summary: Review events above for security threats"
Write-Host "note: Suspicious patterns indicated by 'assert: 0' lines"

CODE

